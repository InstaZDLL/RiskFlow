<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="RiskFlow.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RiskFlow.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Title}"
    CloseButtonText="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Common_Close}"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">840</x:Double>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="600" HorizontalScrollMode="Disabled">
        <Grid Width="760" ColumnSpacing="16" Padding="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Colonne gauche -->
            <StackPanel Grid.Column="0" Spacing="16">
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Appearance}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <RadioButtons Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Theme}" MaxColumns="3"
                                      SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
                            <RadioButton Tag="Common_System" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Theme_Light" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Theme_Dark" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                        </RadioButtons>
                        <RadioButtons Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Language}" MaxColumns="3"
                                      SelectedIndex="{x:Bind ViewModel.LanguageIndex, Mode=TwoWay}">
                            <RadioButton Tag="Common_System" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Lang_French" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Lang_English" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                        </RadioButtons>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_MatrixDisplay}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <RadioButtons Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Placement}"
                                      SelectedIndex="{x:Bind ViewModel.MatrixPlacementIndex, Mode=TwoWay}">
                            <RadioButton Tag="Placement_Tabs" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Placement_Below" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                        </RadioButtons>
                        <RadioButtons Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_CellContent}"
                                      SelectedIndex="{x:Bind ViewModel.MatrixCellContentIndex, Mode=TwoWay}">
                            <RadioButton Tag="Cell_Numbers" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Cell_Count" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                        </RadioButtons>
                        <RadioButtons Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_DefaultEval}"
                                      SelectedIndex="{x:Bind ViewModel.MatrixEvalIndex, Mode=TwoWay}">
                            <RadioButton Tag="Matrix_Before" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                            <RadioButton Tag="Matrix_After" Content="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource L}}" />
                        </RadioButtons>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_About}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Width="48" Height="48" VerticalAlignment="Top"
                                   Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="RiskFlow" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="© 2026 InstaZDLL · Licence Apache 2.0"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <HyperlinkButton Content="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_SourceCode}" Padding="0"
                                         NavigateUri="https://github.com/InstaZDLL/RiskFlow" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Colonne droite -->
            <StackPanel Grid.Column="1" Spacing="16">
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Report}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_ReportHint}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Common_Author}"
                                 Text="{x:Bind ViewModel.ReportAuthor, Mode=TwoWay}" />
                        <TextBox Header="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Common_Organization}"
                                 Text="{x:Bind ViewModel.ReportOrganization, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_Categories}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryRowViewModel">
                                    <Grid ColumnSpacing="8" Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{x:Bind Name, Mode=TwoWay}"
                                                 LostFocus="OnCategoryRenamed" />
                                        <Button Grid.Column="1" Click="OnDeleteCategory"
                                                ToolTipService.ToolTip="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Common_Delete}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid ColumnSpacing="8" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" PlaceholderText="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Settings_NewCategory}"
                                     Text="{x:Bind ViewModel.NewCategoryName, Mode=TwoWay}" />
                            <Button Grid.Column="1" Content="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Common_Add}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.AddCategoryCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ContentDialog>
