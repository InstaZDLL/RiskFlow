<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="RiskFlow.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RiskFlow.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Réglages"
    CloseButtonText="Fermer"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">840</x:Double>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="600" HorizontalScrollMode="Disabled">
        <Grid Width="760" ColumnSpacing="16" Padding="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Colonne gauche -->
            <StackPanel Grid.Column="0" Spacing="16">
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Apparence" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <RadioButtons Header="Thème" MaxColumns="3"
                                      SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
                            <x:String>Système</x:String>
                            <x:String>Clair</x:String>
                            <x:String>Sombre</x:String>
                        </RadioButtons>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Affichage de la matrice" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <RadioButtons Header="Emplacement"
                                      SelectedIndex="{x:Bind ViewModel.MatrixPlacementIndex, Mode=TwoWay}">
                            <x:String>Onglets Registre / Matrice</x:String>
                            <x:String>Sous le tableau</x:String>
                        </RadioButtons>
                        <RadioButtons Header="Contenu des cellules"
                                      SelectedIndex="{x:Bind ViewModel.MatrixCellContentIndex, Mode=TwoWay}">
                            <x:String>Numéros des risques</x:String>
                            <x:String>Compteur</x:String>
                        </RadioButtons>
                        <RadioButtons Header="Évaluation par défaut"
                                      SelectedIndex="{x:Bind ViewModel.MatrixEvalIndex, Mode=TwoWay}">
                            <x:String>Avant mitigation</x:String>
                            <x:String>Après mitigation</x:String>
                        </RadioButtons>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="À propos" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Width="48" Height="48" VerticalAlignment="Top"
                                   Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="RiskFlow" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="© 2026 InstaZDLL · Licence Apache 2.0"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <HyperlinkButton Content="Code source (GitHub)" Padding="0"
                                         NavigateUri="https://github.com/InstaZDLL/RiskFlow" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Colonne droite -->
            <StackPanel Grid.Column="1" Spacing="16">
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Rapport (export PDF)" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Valeurs par défaut, surchargeables par analyse."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox Header="Auteur" Text="{x:Bind ViewModel.ReportAuthor, Mode=TwoWay}" />
                        <TextBox Header="Organisation" Text="{x:Bind ViewModel.ReportOrganization, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Catégories de risques" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryRowViewModel">
                                    <Grid ColumnSpacing="8" Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{x:Bind Name, Mode=TwoWay}"
                                                 LostFocus="OnCategoryRenamed" />
                                        <Button Grid.Column="1" Click="OnDeleteCategory"
                                                ToolTipService.ToolTip="Supprimer">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid ColumnSpacing="8" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" PlaceholderText="Nouvelle catégorie…"
                                     Text="{x:Bind ViewModel.NewCategoryName, Mode=TwoWay}" />
                            <Button Grid.Column="1" Content="Ajouter"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.AddCategoryCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ContentDialog>
