<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RiskFlow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RiskFlow"
    xmlns:risks="using:RiskFlow.Core.Risks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="RiskFlow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="Nav"
                    IsSettingsVisible="True"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="Left"
                    SelectionChanged="OnNavSelectionChanged">

        <NavigationView.PaneHeader>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0,4,0" VerticalAlignment="Center">
                <Button Click="OnNewAnalysisClick" Height="34"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Pane_NewAnalysis}" />
                    </StackPanel>
                </Button>
                <Button Click="OnImportClick" Height="34"
                        ToolTipService.ToolTip="{Binding Source={StaticResource Loc}, Converter={StaticResource L}, ConverterParameter=Pane_Import}">
                    <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                </Button>
            </StackPanel>
        </NavigationView.PaneHeader>

        <Grid x:Name="ContentHost" />
    </NavigationView>
</Window>
