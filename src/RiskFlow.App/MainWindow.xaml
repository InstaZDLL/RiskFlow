<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RiskFlow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RiskFlow"
    xmlns:risks="using:RiskFlow.Core.Risks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="RiskFlow">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="Nav"
                    IsSettingsVisible="True"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="Left"
                    MenuItemsSource="{x:Bind ViewModel.Analyses}"
                    SelectionChanged="OnNavSelectionChanged">

        <NavigationView.PaneHeader>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0,4,0" VerticalAlignment="Center">
                <Button Click="OnNewAnalysisClick" Height="34"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="13" />
                        <TextBlock Text="Nouvelle analyse" />
                    </StackPanel>
                </Button>
                <Button Click="OnImportClick" Height="34" ToolTipService.ToolTip="Importer une analyse (JSON)">
                    <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                </Button>
            </StackPanel>
        </NavigationView.PaneHeader>

        <NavigationView.MenuItemTemplate>
            <DataTemplate x:DataType="risks:Analysis">
                <StackPanel Spacing="0">
                    <StackPanel.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Modifier…" Click="OnEditAnalysisMenuClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70F;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Supprimer" Click="OnDeleteAnalysisClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </StackPanel.ContextFlyout>
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind Model.Dimensions}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </DataTemplate>
        </NavigationView.MenuItemTemplate>

        <Grid x:Name="ContentHost" />
    </NavigationView>
</Window>
