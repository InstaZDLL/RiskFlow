<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RiskFlow.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RiskFlow"
    xmlns:conv="using:RiskFlow.Converters"
    xmlns:vm="using:RiskFlow.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <conv:RiskLevelToBrushConverter x:Key="LevelBrush" />
        <conv:RiskLevelToLabelConverter x:Key="LevelLabel" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CanContinueToTextConverter x:Key="ContinueText" />
        <conv:CanContinueToBrushConverter x:Key="ContinueBrush" />

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinWidth" Value="118" />
        </Style>
    </Page.Resources>

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ===== Colonne gauche ===== -->
        <Grid Grid.Column="0" Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- En-tête commun -->
            <StackPanel Grid.Row="0" Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.AnalysisName, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <Button Click="OnEditAnalysisClick"
                            Width="34" Height="34" Padding="0" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Modifier l'analyse">
                        <FontIcon Glyph="&#xE70F;" FontSize="15" />
                    </Button>
                </StackPanel>
                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="modèle" />
                    <Run Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" />
                </TextBlock>

                <!-- Cartes de synthèse -->
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.TotalRisks, Mode=OneWay}"
                                       FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="Risques" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.CriticalCount, Mode=OneWay}"
                                       FontSize="24" FontWeight="SemiBold" Foreground="#DC2626" />
                            <TextBlock Text="Critiques" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.HighCount, Mode=OneWay}"
                                       FontSize="24" FontWeight="SemiBold" Foreground="#F97316" />
                            <TextBlock Text="Élevés" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.BlockedCount, Mode=OneWay}"
                                       FontSize="24" FontWeight="SemiBold" Foreground="#6B7280" />
                            <TextBlock Text="Non poursuivables" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Sélecteur de vue -->
            <SelectorBar Grid.Row="1" x:Name="ViewSelector" SelectionChanged="OnViewChanged">
                <SelectorBarItem x:Name="RegistreTab" Text="Registre" IsSelected="True" />
                <SelectorBarItem x:Name="MatriceTab" Text="Matrice" />
            </SelectorBar>

            <!-- ===== Vue Registre ===== -->
            <Grid x:Name="RegistreView" Grid.Row="2" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="Ajouter un risque"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.AddRiskCommand}" />
                    <Button Content="Supprimer"
                            Command="{x:Bind ViewModel.DeleteRiskCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedRow, Mode=OneWay}" />
                    <Button Click="OnExportPdfClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE749;" FontSize="14" />
                            <TextBlock Text="Exporter PDF" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <ListView ItemsSource="{x:Bind ViewModel.Rows}"
                              SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollMode="Enabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="10"
                                      Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Groupes -->
                                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                                            Margin="0,0,0,6" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="IDENTIFICATION" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3"
                                            Margin="0,0,0,6" CornerRadius="4" Padding="6,2" Background="#33F59E0B">
                                        <TextBlock Text="AVANT ATTÉNUATION" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="7" Grid.ColumnSpan="4"
                                            Margin="0,0,0,6" CornerRadius="4" Padding="6,2" Background="#3310B981">
                                        <TextBlock Text="APRÈS ATTÉNUATION" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </Border>

                                    <!-- Colonnes -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="N°" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Titre" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Catégorie" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Description" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Gravité" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="5" Text="Probabilité" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="6" Text="Niveau" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="7" Text="Stratégie" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="8" Text="Gravité" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="9" Text="Probabilité" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="10" Text="Niveau" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Grid.Column="11" Text="Continuer ?" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RiskRowViewModel">
                                <Grid Padding="12,10" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Top"
                                               Text="{x:Bind RiskNumber}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Top" TextWrapping="Wrap"
                                               Text="{x:Bind Title, Mode=OneWay}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Top"
                                               Text="{x:Bind Category, Mode=OneWay}" />
                                    <TextBlock Grid.Column="3" VerticalAlignment="Top" TextWrapping="Wrap"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{x:Bind Description, Mode=OneWay}" />

                                    <TextBlock Grid.Column="4" VerticalAlignment="Top"
                                               Text="{x:Bind BeforeSeverityLabel, Mode=OneWay}" />
                                    <TextBlock Grid.Column="5" VerticalAlignment="Top"
                                               Text="{x:Bind BeforeLikelihoodLabel, Mode=OneWay}" />
                                    <Border Grid.Column="6" HorizontalAlignment="Left" VerticalAlignment="Top"
                                            CornerRadius="4" Padding="8,2"
                                            Background="{x:Bind BeforeLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                                   Text="{x:Bind BeforeLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                                    </Border>

                                    <TextBlock Grid.Column="7" VerticalAlignment="Top" TextWrapping="Wrap"
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{x:Bind MitigationStrategy, Mode=OneWay}" />

                                    <TextBlock Grid.Column="8" VerticalAlignment="Top"
                                               Text="{x:Bind AfterSeverityLabel, Mode=OneWay}" />
                                    <TextBlock Grid.Column="9" VerticalAlignment="Top"
                                               Text="{x:Bind AfterLikelihoodLabel, Mode=OneWay}" />
                                    <Border Grid.Column="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                                            CornerRadius="4" Padding="8,2"
                                            Background="{x:Bind AfterLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                                   Text="{x:Bind AfterLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                                    </Border>

                                    <Border Grid.Column="11" HorizontalAlignment="Left" VerticalAlignment="Top"
                                            CornerRadius="4" Padding="8,2"
                                            Background="{x:Bind CanContinue, Mode=OneWay, Converter={StaticResource ContinueBrush}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                                   Text="{x:Bind CanContinue, Mode=OneWay, Converter={StaticResource ContinueText}}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <!-- ===== Vue Matrice ===== -->
            <Grid x:Name="MatriceView" Grid.Row="2" RowSpacing="12" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Évaluation :" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ToggleSwitch x:Name="EvalToggle" MinWidth="0"
                                  OffContent="Avant mitigation" OnContent="Après mitigation"
                                  Toggled="OnEvalToggled" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" x:Name="MatrixScroll"
                              HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid Padding="12"
                          MinWidth="{x:Bind MatrixScroll.ViewportWidth, Mode=OneWay}"
                          MinHeight="{x:Bind MatrixScroll.ViewportHeight, Mode=OneWay}">
                        <Grid x:Name="MatrixHost"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ===== Colonne droite : panneau de détail ===== -->
        <Border Grid.Column="1" Width="380"
                Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer>
                <StackPanel Padding="20" Spacing="14">
                    <Grid>
                        <TextBlock Text="Détail du risque" VerticalAlignment="Center"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="32" Height="32" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Fermer"
                                Command="{x:Bind ViewModel.CloseDetailCommand}">
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </Grid>

                    <TextBox Header="Titre"
                             Text="{x:Bind ViewModel.SelectedRow.Title, Mode=TwoWay}" />

                    <ComboBox Header="Catégorie" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.Categories}"
                              SelectedItem="{x:Bind ViewModel.SelectedRow.Category, Mode=TwoWay}" />

                    <TextBox Header="Description" TextWrapping="Wrap" AcceptsReturn="True" Height="72"
                             Text="{x:Bind ViewModel.SelectedRow.Description, Mode=TwoWay}" />

                    <!-- Avant mitigation -->
                    <TextBlock Text="Avant mitigation" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Header="Gravité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.SeverityLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.BeforeSeverityIndex, Mode=TwoWay}" />
                        <ComboBox Grid.Column="1" Header="Probabilité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.LikelihoodLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.BeforeLikelihoodIndex, Mode=TwoWay}" />
                    </Grid>
                    <Border HorizontalAlignment="Left" CornerRadius="4" Padding="10,3"
                            Background="{x:Bind ViewModel.SelectedRow.BeforeLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                   Text="{x:Bind ViewModel.SelectedRow.BeforeLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                    </Border>

                    <TextBox Header="Stratégie de mitigation" TextWrapping="Wrap" AcceptsReturn="True" Height="72"
                             Text="{x:Bind ViewModel.SelectedRow.MitigationStrategy, Mode=TwoWay}" />

                    <!-- Après mitigation -->
                    <TextBlock Text="Après mitigation" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Header="Gravité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.SeverityLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.AfterSeverityIndex, Mode=TwoWay}" />
                        <ComboBox Grid.Column="1" Header="Probabilité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.LikelihoodLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.AfterLikelihoodIndex, Mode=TwoWay}" />
                    </Grid>
                    <Border HorizontalAlignment="Left" CornerRadius="4" Padding="10,3"
                            Background="{x:Bind ViewModel.SelectedRow.AfterLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                   Text="{x:Bind ViewModel.SelectedRow.AfterLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                    </Border>

                    <ToggleSwitch Header="Le projet peut continuer"
                                  OnContent="Oui" OffContent="Non"
                                  IsOn="{x:Bind ViewModel.SelectedRow.CanContinue, Mode=TwoWay}" />

                    <Button Content="Enregistrer" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SaveSelectedCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Confirmation de sauvegarde (discrète, auto-masquée) -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,28" Padding="14,7" CornerRadius="14"
                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Visibility="{x:Bind ViewModel.SavedMessageVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE73E;" FontSize="13"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="Sauvegardé"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
