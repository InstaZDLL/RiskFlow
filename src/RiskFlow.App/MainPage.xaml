<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RiskFlow.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RiskFlow"
    xmlns:conv="using:RiskFlow.Converters"
    xmlns:vm="using:RiskFlow.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <conv:RiskLevelToBrushConverter x:Key="LevelBrush" />
        <conv:RiskLevelToLabelConverter x:Key="LevelLabel" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CanContinueToTextConverter x:Key="ContinueText" />
        <conv:CanContinueToBrushConverter x:Key="ContinueBrush" />
    </Page.Resources>

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ===== Colonne gauche ===== -->
        <Grid Grid.Column="0" Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- En-tête commun -->
            <StackPanel Grid.Row="0" Spacing="2">
                <TextBlock Text="{x:Bind ViewModel.AnalysisName, Mode=OneWay}"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="modèle" />
                    <Run Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>

            <!-- Sélecteur de vue -->
            <SelectorBar Grid.Row="1" x:Name="ViewSelector" SelectionChanged="OnViewChanged">
                <SelectorBarItem x:Name="RegistreTab" Text="Registre" IsSelected="True" />
                <SelectorBarItem x:Name="MatriceTab" Text="Matrice" />
            </SelectorBar>

            <!-- ===== Vue Registre ===== -->
            <Grid x:Name="RegistreView" Grid.Row="2" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="Ajouter un risque"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.AddRiskCommand}" />
                    <Button Content="Supprimer"
                            Command="{x:Bind ViewModel.DeleteRiskCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedRow, Mode=OneWay}" />
                </StackPanel>

                <Border Grid.Row="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <ListView ItemsSource="{x:Bind ViewModel.Rows}"
                              SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="12"
                                      Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="N°" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="Titre" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="Catégorie" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="Avant" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="Après" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="5" Text="Continuer ?" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RiskRowViewModel">
                                <Grid Padding="0,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                               Text="{x:Bind RiskNumber}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               Text="{x:Bind Title, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Text="{x:Bind Category, Mode=OneWay}" />

                                    <Border Grid.Column="3" HorizontalAlignment="Left"
                                            CornerRadius="4" Padding="8,2"
                                            Background="{x:Bind BeforeLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                                   Text="{x:Bind BeforeLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                                    </Border>

                                    <Border Grid.Column="4" HorizontalAlignment="Left"
                                            CornerRadius="4" Padding="8,2"
                                            Background="{x:Bind AfterLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                                   Text="{x:Bind AfterLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                                    </Border>

                                    <Border Grid.Column="5" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            CornerRadius="4" Padding="8,2"
                                            Background="{x:Bind CanContinue, Mode=OneWay, Converter={StaticResource ContinueBrush}}">
                                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                                   Text="{x:Bind CanContinue, Mode=OneWay, Converter={StaticResource ContinueText}}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <!-- ===== Vue Matrice ===== -->
            <Grid x:Name="MatriceView" Grid.Row="2" RowSpacing="12" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Évaluation :" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ToggleSwitch x:Name="EvalToggle" MinWidth="0"
                                  OffContent="Avant mitigation" OnContent="Après mitigation"
                                  Toggled="OnEvalToggled" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" x:Name="MatrixScroll"
                              HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid Padding="12"
                          MinWidth="{x:Bind MatrixScroll.ViewportWidth, Mode=OneWay}"
                          MinHeight="{x:Bind MatrixScroll.ViewportHeight, Mode=OneWay}">
                        <Grid x:Name="MatrixHost"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ===== Colonne droite : panneau de détail ===== -->
        <Border Grid.Column="1" Width="380"
                Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer>
                <StackPanel Padding="20" Spacing="14">
                    <Grid>
                        <TextBlock Text="Détail du risque" VerticalAlignment="Center"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="32" Height="32" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Fermer"
                                Command="{x:Bind ViewModel.CloseDetailCommand}">
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </Grid>

                    <TextBox Header="Titre"
                             Text="{x:Bind ViewModel.SelectedRow.Title, Mode=TwoWay}" />

                    <ComboBox Header="Catégorie" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.Categories}"
                              SelectedItem="{x:Bind ViewModel.SelectedRow.Category, Mode=TwoWay}" />

                    <TextBox Header="Description" TextWrapping="Wrap" AcceptsReturn="True" Height="72"
                             Text="{x:Bind ViewModel.SelectedRow.Description, Mode=TwoWay}" />

                    <!-- Avant mitigation -->
                    <TextBlock Text="Avant mitigation" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Header="Gravité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.SeverityLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.BeforeSeverityIndex, Mode=TwoWay}" />
                        <ComboBox Grid.Column="1" Header="Probabilité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.LikelihoodLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.BeforeLikelihoodIndex, Mode=TwoWay}" />
                    </Grid>
                    <Border HorizontalAlignment="Left" CornerRadius="4" Padding="10,3"
                            Background="{x:Bind ViewModel.SelectedRow.BeforeLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                   Text="{x:Bind ViewModel.SelectedRow.BeforeLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                    </Border>

                    <TextBox Header="Stratégie de mitigation" TextWrapping="Wrap" AcceptsReturn="True" Height="72"
                             Text="{x:Bind ViewModel.SelectedRow.MitigationStrategy, Mode=TwoWay}" />

                    <!-- Après mitigation -->
                    <TextBlock Text="Après mitigation" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Header="Gravité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.SeverityLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.AfterSeverityIndex, Mode=TwoWay}" />
                        <ComboBox Grid.Column="1" Header="Probabilité" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.LikelihoodLevels, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRow.AfterLikelihoodIndex, Mode=TwoWay}" />
                    </Grid>
                    <Border HorizontalAlignment="Left" CornerRadius="4" Padding="10,3"
                            Background="{x:Bind ViewModel.SelectedRow.AfterLevel, Mode=OneWay, Converter={StaticResource LevelBrush}}">
                        <TextBlock Foreground="White" FontWeight="SemiBold"
                                   Text="{x:Bind ViewModel.SelectedRow.AfterLevel, Mode=OneWay, Converter={StaticResource LevelLabel}}" />
                    </Border>

                    <ToggleSwitch Header="Le projet peut continuer"
                                  OnContent="Oui" OffContent="Non"
                                  IsOn="{x:Bind ViewModel.SelectedRow.CanContinue, Mode=TwoWay}" />

                    <Button Content="Enregistrer" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SaveSelectedCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Confirmation de sauvegarde (discrète, auto-masquée) -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,28" Padding="14,7" CornerRadius="14"
                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Visibility="{x:Bind ViewModel.SavedMessageVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE73E;" FontSize="13"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="Sauvegardé"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
